---
import Layout from "@layouts/Layout.astro";

const base_url = import.meta.env.BASE_URL;

const webinars = [
  {
    quarter: "Q1 2026",
    title: "End-to-End Federated AI: From APIs to Multicloud & Edge (with Rhino FCP)",
    description:
      "Learn about NVFlare's latest APIs and Rhino's federated computing foundation for multicloud, edge, and agentic AI workflows.",
    link: "https://www.youtube.com/watch?v=PhhIeD_TmKs",
    embed_link: "https://www.youtube-nocookie.com/embed/PhhIeD_TmKs?rel=0",
    cta: "Watch recording",
  },
  {
    quarter: "Q4 2025",
    title: "Federated Learning from Industrial Perspectives (by Roche & Apheris)",
    description:
      "Learn how federated learning is shaping advanced use cases across diverse industries from an applied, production-oriented perspective.",
    link: "https://www.youtube.com/watch?v=UPqewo6EMz8",
    cta: "Watch recording",
  },
  {
    quarter: "Q3 2025",
    title: "Provision, Run, and Monitor Federated Learning Applications",
    description:
      "See how to set up, execute, and monitor federated learning applications across a real system lifecycle.",
    link: "https://www.youtube.com/watch?v=w_li8idy3UU",
    cta: "Watch recording",
  },
  {
    quarter: "Q2 2025",
    title: "Federated Learning Applications: Healthcare and Finance",
    description:
      "Explore how federated learning is transforming two of the most critical industries, driving innovation while preserving data privacy.",
    link: "",
    cta: "Recording pending",
  },
  {
    quarter: "Q1 2025",
    title: "Introduction to NVIDIA Federated Learning: Concepts, Technology, and Use Cases",
    description:
      "Kick off the series with a comprehensive dive into federated learning fundamentals, the technology that powers it, and real-world use cases.",
    link: "https://www.youtube.com/watch?v=7vAQFMweg0Q",
    cta: "Watch recording",
  },
];

const [featured_webinar, ...archived_webinars] = webinars;
---

<Layout title="Webinars">
  <div class="bg-white py-16 sm:py-16">
    <div class="mx-auto max-w-[1600px] px-6 lg:px-8">
      <div class="mx-auto max-w-5xl mt-10 flex justify-start">
        <a href={base_url} class="text-sm font-semibold leading-6 text-nvidia">
          <span aria-hidden="true">&larr;</span>
          Back to home
        </a>
      </div>

      <div class="mx-auto max-w-5xl mt-16 md:mt-0 text-center">
        <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">
          NVIDIA FLARE Webinars
        </h2>
        <p class="text-lg mt-4 text-slate-600 w-3/4 m-auto">
          Explore NVIDIA FLARE webinars, from foundational concepts to real-world federated AI deployments.
        </p>
      </div>

      <div class="mx-auto mt-16 max-w-5xl">
        <div class="rounded-3xl bg-black px-8 py-10 text-left text-neutral-200 shadow-xl">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-nvidia">
            Webinar Series
          </p>
          <h3 class="mt-3 text-3xl font-bold sm:text-4xl">
            Recorded sessions and upcoming events
          </h3>
        </div>

        <div class="mt-10 grid gap-6 lg:grid-cols-[minmax(0,1.3fr)_minmax(320px,0.7fr)]">
          <div class="overflow-hidden rounded-3xl bg-black shadow-xl ring-1 ring-black/10">
            <div class="aspect-video">
              <iframe
                class="h-full w-full"
                src={featured_webinar.embed_link}
                title={featured_webinar.title}
                loading="lazy"
                referrerpolicy="strict-origin-when-cross-origin"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
              />
            </div>
          </div>

          <div class="rounded-3xl border border-gray-200 bg-white px-8 py-8 text-left shadow-sm">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-nvidia">
              Featured Webinar
            </p>
            <p class="mt-3 text-sm font-semibold uppercase tracking-[0.14em] text-slate-500">
              {featured_webinar.quarter}
            </p>
            <h3 class="mt-2 text-2xl font-semibold leading-tight text-gray-900">
              {featured_webinar.title}
            </h3>
            <p class="mt-4 text-base leading-7 text-slate-600">
              {featured_webinar.description}
            </p>
            <div class="mt-6">
              <a
                href={featured_webinar.link}
                class="inline-flex rounded-md bg-nvidia px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-green-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-nvidia"
              >
                Watch on YouTube
              </a>
            </div>
          </div>
        </div>

        <div class="mt-14 text-left">
          <h3 class="text-2xl font-semibold text-gray-900">
            More in the series
          </h3>
        </div>

        <div class="mt-8 grid gap-6">
          {
            archived_webinars.map((webinar) => (
              <article class="rounded-3xl border border-gray-200 bg-gray-50 px-8 py-8 shadow-sm transition-shadow hover:shadow-md">
                <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                  <div class="max-w-3xl text-left">
                    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-nvidia">
                      {webinar.quarter}
                    </p>
                    <h3 class="mt-2 text-2xl font-semibold leading-tight text-gray-900">
                      {webinar.title}
                    </h3>
                    <p class="mt-4 text-base leading-7 text-slate-600">
                      {webinar.description}
                    </p>
                  </div>

                  {
                    webinar.link ? (
                      <a
                        href={webinar.link}
                        class="inline-flex whitespace-nowrap rounded-md bg-nvidia px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-green-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-nvidia"
                      >
                        {webinar.cta}
                      </a>
                    ) : (
                      <span class="inline-flex whitespace-nowrap rounded-md bg-white px-4 py-2.5 text-sm font-semibold text-slate-500 ring-1 ring-inset ring-gray-300">
                        {webinar.cta}
                      </span>
                    )
                  }
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</Layout>
